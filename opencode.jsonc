{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,

  // LSP: built-ins auto-install per language (typescript/eslint/oxlint).
  // pyright is disabled in favor of basedpyright (stricter fork, runs via bunx).
  // ruff/tailwindcss/emmet are local servers started via bunx (single runner).
  // Docs warn LSP can be memory-heavy; keep an eye on it per project.
  "lsp": {
    "pyright": { "disabled": true },

    // Local-first; ruff binary (standalone, installed by install.sh).
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    },
    // Stricter Python type checking (basedpyright-langserver via bunx -p).
    "basedpyright": {
      "command": ["bunx", "-p", "basedpyright", "basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    // Tailwind CSS intelligence (only activates on CSS/SCSS).
    "tailwindcss": {
      "command": ["bunx", "@tailwindcss/language-server", "--stdio"],
      "extensions": [".css", ".scss"]
    },
    // Emmet abbreviations in HTML/CSS.
    "emmet": {
      "command": ["bunx", "emmet-language-server", "--stdio"],
      "extensions": [".html", ".css", ".scss"]
    }
  },

  // Prettier for TS/JS; ruff handles Python formatting via the LSP above.
  "formatter": true,

  "mcp": {
    // --- Remote, no credentials (enabled) ---
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },

    // --- Local, no credentials (enabled) ---
    // All servers run through Bun (`bunx`) for a single, portable runner.
    // Bun installs the package on first run, so no global npm/uv needed.
    "fetch": {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-fetch"]
    },
    "sequentialthinking": {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-sequentialthinking"]
    },
    "git": {
      "type": "local",
      "command": ["bunx", "@cyanheads/git-mcp-server"]
    },

    // --- Heavy / needs setup (disabled by default) ---
    // Chrome DevTools: needs Google Chrome installed. Many tools -> high context.
    "chrome-devtools": {
      "type": "local",
      "enabled": false,
      "command": ["bunx", "chrome-devtools-mcp@latest", "--headless"]
    },
    // Playwright: browser automation. Token-heavy; enable on demand.
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": ["bunx", "@playwright/mcp@latest", "--headless"]
    },

    // --- Needs API key (disabled) ---
    "brave-search": {
      "type": "local",
      "enabled": false,
      "command": ["bunx", "@brave/brave-search-mcp-server", "--transport", "stdio"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
  },

  "plugin": [
    "opencode-shell-strategy",
    "opencode-notify",
    "opencode-websearch-cited",
    "opencode-dynamic-context-pruning",
    // Memory: local-first, no API key (SQLite + vector index, local embeddings).
    "opencode-mem",
    // Multi-agent orchestrator (shadow agents + auto-delegation).
    // Materialized by `bunx oh-my-opencode-slim@latest install` in install.sh.
    "oh-my-opencode-slim"
  ],

  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md"
  ]
}

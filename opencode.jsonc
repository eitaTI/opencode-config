{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,

  // Granular permission rules — last matching rule wins.
  // "allow" = auto-approve, "ask" = prompt user, "deny" = block.
  "permission": {
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      // Safe read-only commands
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "eza *": "allow",
      "bat *": "allow",
      // Safe read-only commands (PowerShell / Windows — used when pwsh is the shell)
      "type *": "allow",
      "dir *": "allow",
      "Get-Content *": "allow",
      "Get-ChildItem *": "allow",
      "Select-String *": "allow",
      "node -e *": "allow",
      "npx -y *": "allow",
      "python -c *": "allow",
      "python3 -c *": "allow",
      "uvx *": "allow",
      "opencode *": "allow",
      // Destructive commands require approval
      "rm *": "ask",
      "rmdir *": "ask",
      "del *": "ask",
      "git push*": "ask",
      "git commit*": "ask",
      "git reset*": "ask",
      "git clean*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "npm install*": "ask",
      "npm uninstall*": "ask",
      "yarn *": "ask",
      "pnpm *": "ask",
      "bun install*": "ask",
      "pip install*": "ask",
      "pip uninstall*": "ask",
      "uv install*": "ask",
      // Package managers (Arch/CachyOS)
      "sudo pacman *": "ask",
      "yay *": "ask",
      "paru *": "ask"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "external_directory": "ask"
  },

  // LSP: built-ins auto-install per language (typescript/eslint/oxlint).
  // pyright is disabled in favor of basedpyright (stricter fork, runs via npx).
  // ruff/tailwindcss/emmet are local servers started via npx (single runner).
  "lsp": {
    "pyright": { "disabled": true },
    "eslint": { "disabled": true }, // replaced by vscode-eslint-language-server below

    // Local-first; ruff binary (standalone, installed by install.sh).
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    },
    // Stricter Python type checking (basedpyright-langserver via npx -y).
    "basedpyright": {
      "command": ["npx", "-y", "-p", "basedpyright", "basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    // TypeScript/JavaScript (via vtsls — npx runner).
    "vtsls": {
      "command": ["npx", "-y", "@vtsls/language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    },
    // Tailwind CSS intelligence (only activates on CSS/SCSS).
    "tailwindcss": {
      "command": ["npx", "-y", "-p", "@tailwindcss/language-server", "tailwindcss-language-server", "--stdio"],
      "extensions": [".css", ".scss"]
    },
    // Emmet abbreviations in HTML/CSS.
    "emmet": {
      "command": ["npx", "-y", "@olrtg/emmet-language-server", "--stdio"],
      "extensions": [".html", ".css", ".scss"]
    },
    // ESLint LSP (official, extracted from the VS Code ESLint extension).
    // Replaces the built-in eslint LSP to avoid duplicate diagnostics.
    "eslint-lsp": {
      "command": ["npx", "-y", "-p", "vscode-langservers-extracted", "vscode-eslint-language-server", "--stdio"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs"]
    },
    // Bash/Shell scripting.
    "bash-language-server": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash"]
    },
    // Dockerfile support (via npx runner).
    "docker-langserver": {
      "command": ["npx", "-y", "dockerfile-language-server-nodejs", "--stdio"],
      "extensions": ["Dockerfile", ".dockerfile"]
    },
    // YAML configuration files (general YAML support).
    "yaml-language-server": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    // JSON/JSONC support (via npx runner).
    "vscode-json-language-server": {
      "command": ["npx", "-y", "-p", "vscode-langservers-extracted", "vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    // HTML support (via npx runner).
    "vscode-html-language-server": {
      "command": ["npx", "-y", "-p", "vscode-langservers-extracted", "vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    // CSS/SCSS/LESS support (via npx runner).
    "vscode-css-language-server": {
      "command": ["npx", "-y", "-p", "vscode-langservers-extracted", "vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    // Markdown support (via npx runner).
    "vscode-markdown-language-server": {
      "command": ["npx", "-y", "-p", "vscode-langservers-extracted", "vscode-markdown-language-server", "--stdio"],
      "extensions": [".md", ".markdown"]
    }
    // NOTE: ansible-language-server removed — overlaps with yaml-language-server.
    // If you need Ansible linting, install ansible-lint as a binary and add back:
    // "ansible-language-server": {
    //   "command": ["ansible-language-server", "--stdio"],
    //   "extensions": [".yml", ".yaml"]
    // }
  },

  // Prettier for TS/JS; ruff handles Python formatting via the LSP above.
  "formatter": true,

  "mcp": {
    // --- Remote, no credentials (enabled) ---
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },

    // --- Local, no credentials (enabled) ---
    // Most servers run through npx for a portable, zero-install runner.
    // npx installs the package on first run, so no global npm needed.
    // `fetch` uses `uvx` (official Python modelcontextprotocol server);
    // `uv` is installed by the installer and auto-manages its Python.
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    },
    "sequentialthinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/git-mcp-server"]
    },
    // SQLite (local): query .db files. Defaults to an in-memory DB;
    // for a real file, copy this entry with "--db", "/path/to/db".
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "@mokei/mcp-sqlite", "--db", ":memory:"]
    },

    // --- Heavy / needs setup (disabled by default) ---
    // Playwright: browser automation (self-contained; downloads its own browser
    // via `npx playwright install`). Token-heavy; enable on demand.
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"]
    },

    // --- Needs API key (disabled) ---
    "brave-search": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@brave/brave-search-mcp-server", "--transport", "stdio"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
    // NOTE: filesystem and memory MCPs removed — redundant with OpenCode's
    // built-in read/write/edit/glob/grep tools and opencode-mem plugin.
  },

  "plugin": [
    "@tarquinen/opencode-dcp",
    "opencode-mem",
    "opencode-wakatime",
    "opencode-pty",
    "envsitter-guard",
    "opencode-smart-title",
    "openslimedit"
  ],

  "instructions": [
    "AGENTS.md"
  ]
}
